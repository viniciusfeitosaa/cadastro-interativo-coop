# Copie para /opt/coopvitta/docuseal/.env na VPS COOP
# chmod 600 .env

DOCUSEAL_HOST=https://assinaturas.coopvitta.cloud
POSTGRES_PASSWORD=GERE_COM_openssl_rand_base64_32

# Use mail.coopvitta.cloud (alias Docker do Maddy na proxy-network)
SMTP_ADDRESS=mail.coopvitta.cloud
SMTP_PORT=587
SMTP_DOMAIN=mail.coopvitta.cloud
SMTP_USERNAME=noreply@coopvitta.cloud
SMTP_PASSWORD=senha_definida_com_maddy_creds_create
SMTP_FROM=COOPVITTA <noreply@coopvitta.cloud>
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS=true
SMTP_SSL_VERIFY=false

DOCUSEAL_WEB_CONCURRENCY=1
